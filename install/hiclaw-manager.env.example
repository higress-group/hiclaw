# HiClaw Manager Configuration Example
# Copy this file to hiclaw-manager.env and fill in your values.
#
# Required:
#   HICLAW_LLM_API_KEY          - Your LLM API key
#   HICLAW_REGISTRATION_TOKEN   - Random secret (e.g., openssl rand -hex 16)
#   HICLAW_MANAGER_PASSWORD     - Random secret (e.g., openssl rand -hex 16)
#   HICLAW_MANAGER_GATEWAY_KEY  - Random secret (e.g., openssl rand -hex 16)
#
# For interactive setup with auto-configuration, use hiclaw-install.sh instead.

# Language (zh or en)
HICLAW_LANGUAGE=en

# LLM
HICLAW_LLM_PROVIDER=alibaba-cloud
HICLAW_DEFAULT_MODEL=qwen3.5-plus
HICLAW_LLM_API_KEY=your-api-key-here
HICLAW_OPENAI_BASE_URL=

# Admin
HICLAW_ADMIN_USER=admin
HICLAW_ADMIN_PASSWORD=changeme

# Ports
HICLAW_LOCAL_ONLY=1
HICLAW_PORT_GATEWAY=18080
HICLAW_PORT_CONSOLE=18001
HICLAW_PORT_ELEMENT_WEB=18088
HICLAW_PORT_OPENCLAW_CONSOLE=18888

# Matrix
HICLAW_MATRIX_DOMAIN=matrix-local.hiclaw.io:18080
HICLAW_MATRIX_CLIENT_DOMAIN=matrix-client-local.hiclaw.io

# Gateway
HICLAW_AI_GATEWAY_DOMAIN=aigw-local.hiclaw.io
HICLAW_MANAGER_GATEWAY_KEY=

# File System
HICLAW_FS_DOMAIN=fs-local.hiclaw.io
HICLAW_CONSOLE_DOMAIN=
HICLAW_MINIO_USER=admin
HICLAW_MINIO_PASSWORD=changeme

# Internal (required, generate with: openssl rand -hex 16)
HICLAW_MANAGER_PASSWORD=REPLACE_ME
HICLAW_REGISTRATION_TOKEN=REPLACE_ME

# GitHub (optional)
HICLAW_GITHUB_TOKEN=

# Skills Registry (optional)
HICLAW_SKILLS_API_URL=

# Worker images
HICLAW_WORKER_IMAGE=higress-registry.cn-hangzhou.cr.aliyuncs.com/higress/hiclaw-worker:latest
HICLAW_COPAW_WORKER_IMAGE=higress-registry.cn-hangzhou.cr.aliyuncs.com/higress/hiclaw-copaw-worker:latest

# Default Worker runtime (openclaw | copaw)
HICLAW_DEFAULT_WORKER_RUNTIME=openclaw

# Higress WASM plugin image registry
HIGRESS_ADMIN_WASM_PLUGIN_IMAGE_REGISTRY=higress-registry.cn-hangzhou.cr.aliyuncs.com

# Data persistence
HICLAW_DATA_DIR=hiclaw-data
HICLAW_WORKSPACE_DIR=
HICLAW_HOST_SHARE_DIR=
